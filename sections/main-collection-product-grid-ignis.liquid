{{ 'template-collection.css' | asset_url | stylesheet_tag }}
{{ 'component-loading-spinner.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'component-slider.css' | asset_url | stylesheet_tag }}

{% if section.settings.image_shape == 'blob' %}
  {{ 'mask-blobs.css' | asset_url | stylesheet_tag }}
{%- endif -%}

{%- if section.settings.enable_quick_add -%}
  {{ 'quick-add.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'quick-add.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{%- style -%}
  .section-{{ section.id }}-padding {
  padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
  padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  .cpb-brand-page .cpb-contents-nav a,
  .cpb-brand-page .sp-only a {
    color: #000;
  }
  .cpb-brand-page .cpb-contents-nav a:hover,
  .cpb-brand-page .sp-only a:hover {
    color: #000;
  }
  .cpb-brand-page {
    font-family: "ヒラギノ角ゴシック", "Hiragino Sans", "メイリオ", Meiryo, sans-serif;
  }
  .c-heading {
    text-align: center;
    margin-bottom: 1.5rem;
  }
  .c-heading__main {
    font-size: 1.5rem;
    font-weight: 400;
    letter-spacing: 0.15em;
    margin: 0;
    line-height: 1.4;
  }
  .c-heading__sub {
    font-size: 0.875rem;
    font-weight: 400;
    letter-spacing: 0.05em;
    margin: 0.25rem 0 0;
    line-height: 1.5;
  }
  .ignis-io-bridge {
    margin-top: 4rem;
    padding: 3.5rem 1.5rem;
    background: #f5f4ef;
    width: 100vw;
    margin-left: calc(50% - 50vw);
    margin-right: calc(50% - 50vw);
  }
  .ignis-io-bridge__inner {
    max-width: 1080px;
    margin: 0 auto;
  }
  .ignis-io-bridge__header {
    margin-bottom: 2.5rem;
    text-align: center;
    color: #7d766d;
  }
  .ignis-io-bridge__title {
    margin: 0;
    font-size: clamp(1.875rem, 4vw, 2.5rem);
    font-weight: 300;
    line-height: 1.1;
    letter-spacing: 0.38em;
    text-indent: 0.38em;
  }
  .ignis-io-bridge__catchcopy {
    margin: 1rem 0 0;
    font-size: 0.9375rem;
    line-height: 1.8;
    letter-spacing: 0.16em;
  }
  .ignis-io-bridge__body {
    display: grid;
    gap: 2rem;
    align-items: center;
  }
  .ignis-io-bridge__image-wrap {
    width: 100%;
    max-width: 420px;
    margin: 0 auto;
  }
  .ignis-io-bridge__image {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 1;
    object-fit: cover;
  }
  .ignis-io-bridge__content {
    text-align: center;
    color: #6f685f;
  }
  .ignis-io-bridge__lead {
    margin: 0;
    font-size: 1.3rem;
    line-height: 2.1;
    letter-spacing: 0.08em;
  }
  .ignis-io-bridge__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 16rem;
    margin-top: 2rem;
    padding: 1.1rem 1.75rem;
    border: 1px solid #b9b1a7;
    color: #898177;
    background: transparent;
    font-size: 1.3rem;
    line-height: 1;
    letter-spacing: 0.2em;
    text-decoration: none;
    transition: background-color 0.2s ease, border-color 0.2s ease, color 0.2s ease;
  }
  .ignis-io-bridge__button:hover {
    background: rgba(255, 255, 255, 0.72);
    border-color: #9c9388;
    color: #6f685f;
  }
  @media screen and (min-width: 750px) {
  .section-{{ section.id }}-padding {
  padding-top: {{ section.settings.padding_top }}px;
  padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  .c-heading__main {
    font-size: 1.75rem;
    letter-spacing: 0.2em;
  }
  .c-heading__sub {
    font-size: 0.9375rem;
  }
  .ignis-io-bridge {
    margin-top: 5.5rem;
    padding: 5rem 4rem 5.25rem;
  }
  .ignis-io-bridge__header {
    margin-bottom: 4rem;
  }
  .ignis-io-bridge__catchcopy {
    font-size: 1rem;
  }
  .ignis-io-bridge__body {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 5.5rem;
  }
  .ignis-io-bridge__image-wrap {
    justify-self: end;
    margin: 0;
  }
  .ignis-io-bridge__content {
    text-align: left;
    justify-self: start;
    max-width: 420px;
  }
  .ignis-io-bridge__lead {
    font-size: 1.6rem;
  }
  .ignis-io-bridge__button {
    font-size: 1.6rem;
  }
  }
{%- endstyle -%}

{%- liquid
  assign products_to_display = section.settings.products_to_show

  assign show_mobile_slider = false
  assign show_mobile_slider = true

  assign show_desktop_slider = false
  assign show_desktop_slider = true

  # Determine selected tag from Storefront Filtering (filter.p.tag) または旧来の current_tags
  assign filter_tag = ''
  for filter in collection.filters
    if filter.param_name == 'filter.p.tag'
      if filter.active_values != blank
        assign filter_tag = filter.active_values.first.label
      endif
      break
    endif
  endfor
  if filter_tag == ''
    assign filter_tag = current_tags | first
  endif
-%}

<!-- IGNIS -->
<div class="item-list cpb-brand-page">
  {% if filter_tag %}
    <!-- IGNIS商品一覧ここから -->
    <div class="page-width tw-my-5">
      <h3 class="tw-text-2xl tw-font-bold tw-my-2">{{ filter_tag }}</h3>
    </div>
    <div class="section-{{ section.id }}-padding">
      {%- paginate collection.products by section.settings.products_per_page -%}
        {% comment %} Sort is the first tabbable element when filter type is vertical {% endcomment %}
        {%- if section.settings.enable_sorting and section.settings.filter_type == 'vertical' -%}
          <facet-filters-form class="facets facets-vertical-sort page-width small-hide no-js-hidden">
            <form class="facets-vertical-form" id="FacetSortForm">
              <div class="facet-filters sorting caption">
                <div class="facet-filters__field">
                  <h2 class="facet-filters__label caption-large text-body">
                    <label for="SortBy">{{ 'products.facets.sort_by_label' | t }}</label>
                  </h2>
                  <div class="select">
                    {%- assign sort_by = collection.sort_by | default: collection.default_sort_by -%}
                    <select
                      name="sort_by"
                      class="facet-filters__sort select__select caption-large"
                      id="SortBy"
                      aria-describedby="a11y-refresh-page-message"
                    >
                      {%- for option in collection.sort_options -%}
                        <option
                          value="{{ option.value | escape }}"
                          {% if option.value == sort_by %}
                            selected="selected"
                          {% endif %}
                        >
                          {{ option.name | escape }}
                        </option>
                      {%- endfor -%}
                    </select>
                    {% render 'icon-caret' %}
                  </div>
                </div>
                <noscript>
                  <button type="submit" class="facets__button-no-js button button--secondary">
                    {{ 'products.facets.sort_button' | t }}
                  </button>
                </noscript>
              </div>

              <div class="product-count-vertical light" role="status">
                <h2 class="product-count__text text-body">
                  <span id="ProductCountDesktop">
                    {%- if collection.results_count -%}
                      {{
                        'templates.search.results_with_count'
                        | t: terms: collection.terms, count: collection.results_count
                      }}
                    {%- elsif collection.products_count == collection.all_products_count -%}
                      {{ 'products.facets.product_count_simple' | t: count: collection.products_count }}
                    {%- else -%}
                      {{
                        'products.facets.product_count'
                        | t: product_count: collection.products_count, count: collection.all_products_count
                      }}
                    {%- endif -%}
                  </span>
                </h2>
                <div class="loading__spinner">
                  <svg
                    aria-hidden="true"
                    focusable="false"
                    class="spinner"
                    viewBox="0 0 66 66"
                    xmlns="http://www.w3.org/2000/svg"
                  >
                    <circle class="path" fill="none" stroke-width="6" cx="33" cy="33" r="30"></circle>
                  </svg>
                </div>
              </div>
            </form>
          </facet-filters-form>
        {%- endif -%}

        <div class="{% if section.settings.filter_type == 'vertical' %} facets-vertical page-width{% endif %}">
          {{ 'component-facets.css' | asset_url | stylesheet_tag }}
          <script src="{{ 'facets.js' | asset_url }}" defer="defer"></script>
          {%- if section.settings.enable_filtering or section.settings.enable_sorting -%}
            <aside
              aria-labelledby="verticalTitle"
              class="facets-wrapper{% unless section.settings.enable_filtering %} facets-wrapper--no-filters{% endunless %}{% if section.settings.filter_type != 'vertical' %} page-width{% endif %}"
              id="main-collection-filters"
              data-id="{{ section.id }}"
            >
              {% render 'facets',
                results: collection,
                enable_filtering: section.settings.enable_filtering,
                enable_sorting: section.settings.enable_sorting,
                filter_type: section.settings.filter_type,
                paginate: paginate
              %}
            </aside>
          {%- endif -%}

          <div
            class="product-grid-container{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
            id="ProductGridContainer"
            {% if settings.animations_reveal_on_scroll %}
              data-cascade
            {% endif %}
          >
            {%- if collection.products.size == 0 -%}
              <div class="collection collection--empty page-width" id="product-grid" data-id="{{ section.id }}">
                <div class="loading-overlay gradient"></div>
                <div class="title-wrapper center">
                  <h2 class="title title--primary">
                    {{ 'sections.collection_template.empty' | t -}}
                    <br>
                    {{
                      'sections.collection_template.use_fewer_filters_html'
                      | t: link: collection.url, class: 'underlined-link link'
                    }}
                  </h2>
                </div>
              </div>
            {%- else -%}
              <div class="collection{% if section.settings.filter_type != 'vertical' %} page-width{% endif %}">
                <div class="loading-overlay gradient"></div>

                <ul
                  id="product-grid"
                  data-id="{{ section.id }}"
                  class="
                    grid product-grid grid--{{ section.settings.columns_mobile }}-col-tablet-down
                    grid--{{ section.settings.columns_desktop }}-col-desktop
                  "
                >
                  {%- for product in collection.products -%}
                    {% assign lazy_load = false %}
                    {%- if forloop.index > 2 -%}
                      {%- assign lazy_load = true -%}
                    {%- endif -%}
                    <li
                      class="grid__item{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
                      {% if settings.animations_reveal_on_scroll %}
                        data-cascade
                        style="--animation-order: {{ forloop.index }};"
                      {% endif %}
                    >
                      {% render 'card-product',
                        card_product: product,
                        media_aspect_ratio: section.settings.image_ratio,
                        image_shape: section.settings.image_shape,
                        show_secondary_image: section.settings.show_secondary_image,
                        show_vendor: section.settings.show_vendor,
                        show_rating: section.settings.show_rating,
                        lazy_load: lazy_load,
                        show_quick_add: section.settings.enable_quick_add,
                        max_title_length: section.settings.max_title_length,
                        section_id: section.id
                      %}
                    </li>
                  {%- endfor -%}
                </ul>

                {%- if paginate.pages > 1 -%}
                  {% render 'pagination', paginate: paginate, anchor: '' %}
                {%- endif -%}
              </div>
            {%- endif -%}
          </div>
        </div>
      {%- endpaginate -%}
      {% if section.settings.image_shape == 'arch' %}
        {% render 'mask-arch' %}
      {%- endif -%}

      {% render 'sp-navigation-ignis' %}
    </div>
    <!-- IGNIS商品一覧ここまで -->
  {% else %}
    <!-- IGNISブランドトップ -->
    <div class="page-width">
      {%- if section.settings.new_arrival_collection != blank -%}
      <div class="cpb-items tw-my-10">
        <div class="c-heading">
          <h2 class="c-heading__main">New Items & Colors</h2>
          <p class="c-heading__sub">新商品・新色情報</p>
        </div>
        <slider-component class="slider-mobile-gutter{% if section.settings.full_width %} slider-component-full-width{% endif %}{% if show_mobile_slider == false %} page-width{% endif %}{% if show_desktop_slider == false and section.settings.full_width == false %} page-width-desktop{% endif %}{% if show_desktop_slider %} slider-component-desktop{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
          <ul
            id="Slider-{{ section.id }}-new-arrival"
            class="grid product-grid contains-card contains-card--product{% if settings.card_style == 'standard' %} contains-card--standard{% endif %} grid--{{ section.settings.columns_desktop }}-col-desktop{% if section.settings.new_arrival_collection == blank %} grid--2-col-tablet-down{% else %} grid--{{ section.settings.columns_mobile }}-col-tablet-down{% endif %}{% if show_mobile_slider or show_desktop_slider %} slider{% if show_desktop_slider %} slider--desktop{% endif %}{% if show_mobile_slider %} slider--tablet grid--peek{% endif %}{% endif %}"
            role="list"
            aria-label="{{ 'general.slider.name' | t }}"
          >
            {%- for product in section.settings.new_arrival_collection.products limit: section.settings.products_to_show -%}
              <li
                id="Slide-{{ section.id }}-new-arrival-{{ forloop.index }}"
                class="grid__item{% if show_mobile_slider or show_desktop_slider %} slider__slide{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
                {% if settings.animations_reveal_on_scroll %}
                  data-cascade
                  style="--animation-order: {{ forloop.index }};"
                {% endif %}
              >
                {% render 'card-product',
                  card_product: product,
                  media_aspect_ratio: section.settings.image_ratio,
                  image_shape: section.settings.image_shape,
                  show_secondary_image: section.settings.show_secondary_image,
                  show_vendor: section.settings.show_vendor,
                  show_rating: section.settings.show_rating,
                  show_quick_add: section.settings.enable_quick_add,
                  max_title_length: section.settings.max_title_length,
                  section_id: section.id
                %}
              </li>
            {%- endfor -%}
          </ul>
          {%- if show_mobile_slider or show_desktop_slider -%}
            <div class="slider-buttons no-js-hidden">
              <button
                type="button"
                class="slider-button slider-button--prev"
                name="previous"
                aria-label="{{ 'general.slider.previous_slide' | t }}"
                aria-controls="Slider-{{ section.id }}-new-arrival"
              >
                {% render 'icon-caret' %}
              </button>
              <div class="slider-counter caption">
                <span class="slider-counter--current">1</span>
                <span aria-hidden="true"> / </span>
                <span class="visually-hidden">{{ 'general.slider.of' | t }}</span>
                <span class="slider-counter--total">{{ products_to_display }}</span>
              </div>
              <button
                type="button"
                class="slider-button slider-button--next"
                name="next"
                aria-label="{{ 'general.slider.next_slide' | t }}"
                aria-controls="Slider-{{ section.id }}-new-arrival"
              >
                {% render 'icon-caret' %}
              </button>
            </div>
          {%- endif -%}
        </slider-component>
      </div>
      {%- endif -%}
      {%- if section.settings.ranking_collection != blank -%}
      <div class="cpb-items tw-my-10">
        <div class="c-heading">
          <h2 class="c-heading__main">RANKING</h2>
          <p class="c-heading__sub">ランキング</p>
        </div>
        <slider-component class="slider-mobile-gutter{% if section.settings.full_width %} slider-component-full-width{% endif %}{% if show_mobile_slider == false %} page-width{% endif %}{% if show_desktop_slider == false and section.settings.full_width == false %} page-width-desktop{% endif %}{% if show_desktop_slider %} slider-component-desktop{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
          <ul
            id="Slider-{{ section.id }}-ranking"
            class="grid product-grid contains-card contains-card--product{% if settings.card_style == 'standard' %} contains-card--standard{% endif %} grid--{{ section.settings.columns_desktop }}-col-desktop{% if section.settings.ranking_collection == blank %} grid--2-col-tablet-down{% else %} grid--{{ section.settings.columns_mobile }}-col-tablet-down{% endif %}{% if show_mobile_slider or show_desktop_slider %} slider{% if show_desktop_slider %} slider--desktop{% endif %}{% if show_mobile_slider %} slider--tablet grid--peek{% endif %}{% endif %}"
            role="list"
            aria-label="{{ 'general.slider.name' | t }}"
          >
            {%- for product in section.settings.ranking_collection.products limit: section.settings.products_to_show -%}
              <li
                id="Slide-{{ section.id }}-ranking-{{ forloop.index }}"
                class="grid__item{% if show_mobile_slider or show_desktop_slider %} slider__slide{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}{% if section.settings.ranking %} ranking-item{% endif %}"
                {% if settings.animations_reveal_on_scroll %}
                  data-cascade
                  style="--animation-order: {{ forloop.index }};"
                {% endif %}
              >
                {% if section.settings.ranking %}
                  <span class="rank">{{ forloop.index }}</span>
                {% endif %}
                {% render 'card-product',
                  card_product: product,
                  media_aspect_ratio: section.settings.image_ratio,
                  image_shape: section.settings.image_shape,
                  show_secondary_image: section.settings.show_secondary_image,
                  show_vendor: section.settings.show_vendor,
                  show_rating: section.settings.show_rating,
                  show_quick_add: section.settings.enable_quick_add,
                  max_title_length: section.settings.max_title_length,
                  section_id: section.id
                %}
              </li>
            {%- endfor -%}
          </ul>
          {%- if show_mobile_slider or show_desktop_slider -%}
            <div class="slider-buttons no-js-hidden">
              <button
                type="button"
                class="slider-button slider-button--prev"
                name="previous"
                aria-label="{{ 'general.slider.previous_slide' | t }}"
                aria-controls="Slider-{{ section.id }}-ranking"
              >
                {% render 'icon-caret' %}
              </button>
              <div class="slider-counter caption">
                <span class="slider-counter--current">1</span>
                <span aria-hidden="true"> / </span>
                <span class="visually-hidden">{{ 'general.slider.of' | t }}</span>
                <span class="slider-counter--total">{{ products_to_display }}</span>
              </div>
              <button
                type="button"
                class="slider-button slider-button--next"
                name="next"
                aria-label="{{ 'general.slider.next_slide' | t }}"
                aria-controls="Slider-{{ section.id }}-ranking"
              >
                {% render 'icon-caret' %}
              </button>
            </div>
          {%- endif -%}
        </slider-component>
      </div>
      {%- endif -%}

      <div class="cpb-contents-nav tw-my-10">
        <div class="c-heading">
          <h2 class="c-heading__main">CATEGORY</h2>
          <p class="c-heading__sub">カテゴリー</p>
        </div>
        <div class="tw-grid tw-grid-cols-2 md:tw-grid-cols-4 tw-gap-4">
          <a class="tw-no-underline tw-text-current" href="{{ routes.collections_url }}/ignis?filter.p.tag=クレンジング#Collection">
            <img class="tw-w-full tw-h-auto md:tw-hidden" src="{{ 'ignis_category_cleansing_tate.jpg' | file_url }}" alt="クレンジング" width="600" height="900">
            <img class="tw-w-full tw-h-auto tw-hidden md:tw-block" src="{{ 'ignis_category_cleansing_yoko.jpg' | file_url }}" alt="クレンジング" width="1200" height="600">
          </a>
          <a class="tw-no-underline tw-text-current" href="{{ routes.collections_url }}/ignis?filter.p.tag=洗顔料#Collection">
            <img class="tw-w-full tw-h-auto md:tw-hidden" src="{{ 'ignis_category_facewash_tate.jpg' | file_url }}" alt="洗顔料" width="600" height="900">
            <img class="tw-w-full tw-h-auto tw-hidden md:tw-block" src="{{ 'ignis_category_facewash_yoko.jpg' | file_url }}" alt="洗顔料" width="1200" height="600">
          </a>
          <a class="tw-no-underline tw-text-current" href="{{ routes.collections_url }}/ignis?filter.p.tag=乳液#Collection">
            <img class="tw-w-full tw-h-auto md:tw-hidden" src="{{ 'ignis_category_milk_tate.jpg' | file_url }}" alt="乳液" width="600" height="900">
            <img class="tw-w-full tw-h-auto tw-hidden md:tw-block" src="{{ 'ignis_category_milk_yoko.jpg' | file_url }}" alt="乳液" width="1200" height="600">
          </a>
          <a class="tw-no-underline tw-text-current" href="{{ routes.collections_url }}/ignis?filter.p.tag=化粧水#Collection">
            <img class="tw-w-full tw-h-auto md:tw-hidden" src="{{ 'ignis_category_lotion_tate.jpg' | file_url }}" alt="化粧水" width="600" height="900">
            <img class="tw-w-full tw-h-auto tw-hidden md:tw-block" src="{{ 'ignis_category_lotion_yoko.jpg' | file_url }}" alt="化粧水" width="1200" height="600">
          </a>
          <a class="tw-no-underline tw-text-current" href="{{ routes.collections_url }}/ignis?filter.p.tag=美容液#Collection">
            <img class="tw-w-full tw-h-auto md:tw-hidden" src="{{ 'ignis_category_essence_tate.jpg' | file_url }}" alt="美容液" width="600" height="900">
            <img class="tw-w-full tw-h-auto tw-hidden md:tw-block" src="{{ 'ignis_category_essence_yoko.jpg' | file_url }}" alt="美容液" width="1200" height="600">
          </a>
          <a class="tw-no-underline tw-text-current" href="{{ routes.collections_url }}/ignis?filter.p.tag=クリーム#Collection">
            <img class="tw-w-full tw-h-auto md:tw-hidden" src="{{ 'ignis_category_cream_tate.jpg' | file_url }}" alt="クリーム" width="600" height="900">
            <img class="tw-w-full tw-h-auto tw-hidden md:tw-block" src="{{ 'ignis_category_cream_yoko.jpg' | file_url }}" alt="クリーム" width="1200" height="600">
          </a>
          <a class="tw-no-underline tw-text-current" href="{{ routes.collections_url }}/ignis?filter.p.tag=スペシャルケア#Collection">
            <img class="tw-w-full tw-h-auto md:tw-hidden" src="{{ 'ignis_category_specialcare_tate.jpg' | file_url }}" alt="スペシャルケア" width="600" height="900">
            <img class="tw-w-full tw-h-auto tw-hidden md:tw-block" src="{{ 'ignis_category_specialcare_yoko.jpg' | file_url }}" alt="スペシャルケア" width="1200" height="600">
          </a>
          <a class="tw-no-underline tw-text-current" href="{{ routes.collections_url }}/ignis?filter.p.tag=雑貨#Collection">
            <img class="tw-w-full tw-h-auto md:tw-hidden" src="{{ 'ignis_category_tools_tate.jpg' | file_url }}" alt="雑貨" width="600" height="900">
            <img class="tw-w-full tw-h-auto tw-hidden md:tw-block" src="{{ 'ignis_category_tools_yoko.jpg' | file_url }}" alt="雑貨" width="1200" height="600">
          </a>
        </div>
      </div>

      <div class="tw-my-3 tw-flex tw-justify-center">
        <a href="https://www.albion.co.jp/counseling/" target="_blank" rel="noopener" class="tw-block tw-w-1/2">
          <img
            class="tw-w-full tw-h-auto"
            src="{{ 'ignis_counseling_banner.jpg' | file_url }}"
            alt="ONLINE COUNSELING オンラインカウンセリング"
            width="1200"
            height="240"
            loading="lazy"
          >
        </a>
      </div>

      <div class="ignis-io-bridge">
        {% assign ignis_io_url = section.settings.ignis_io_all_url | default: '/collections/ignis-io' %}
        <div class="ignis-io-bridge__inner">
          <div class="ignis-io-bridge__header">
            <h2 class="ignis-io-bridge__title">IGNIS iO</h2>
            <p class="ignis-io-bridge__catchcopy">今日はどれでキレイになろう</p>
          </div>
          <div class="ignis-io-bridge__body">
            <div class="ignis-io-bridge__image-wrap">
            <img
              class="ignis-io-bridge__image"
              src="{{ 'ignis_io_top.jpg' | file_url }}"
              alt="IGNIS iO"
              width="600"
              height="600"
              loading="lazy"
            >
            </div>
            <div class="ignis-io-bridge__content">
              <p class="ignis-io-bridge__lead">
                さあ、好きなものを好きなだけ。<br>
                IGNIS iO はわたしのスタイルにあわせて<br>
                自由に選べるアラカルトコスメです。
              </p>
              <a class="ignis-io-bridge__button" href="{{ ignis_io_url }}">
                イグニス イオはこちらへ
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
    <!-- IGNISブランドトップここまで -->
  {% endif %}
</div>
<!-- IGNISここまで -->

