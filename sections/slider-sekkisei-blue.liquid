<script src="{{ 'swiper-init.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign slides = collection.metafields.custom.brand_top_slider.value

  # 商品一覧ページ（view=sekkisei-blue-products）ではスライダーを表示しない
  assign show_slider = true
  if template.suffix == 'sekkisei-blue-products'
    assign show_slider = false
  else
    # フィルタがアクティブな場合もスライダーを表示しない
    assign has_active_filters = false
    for filter in collection.filters
      if filter.active_values != blank
        assign has_active_filters = true
        break
      endif
    endfor
    if current_tags != blank
      assign has_active_filters = true
    endif

    assign has_filtered_results = false
    if collection.products_count != collection.all_products_count
      assign has_filtered_results = true
    endif

    if has_active_filters or has_filtered_results
      assign show_slider = false
    endif
  endif
-%}

{% if show_slider and slides != blank %}
  <div class="page-width">
    <div class="tw-my-6">
      <swiper-container
        class="tw-mx-auto tw-block tw-w-full tw-max-w-[780px]"
        space-between="30"
        effect="fade"
        loop="true"
        autoplay="true"
        init="false"
      >
        {% for slide in slides %}
          {%- liquid
            # 画像未設定のスライドは表示しない（テンプレート初期状態で壊れた画像を出さないため）
            if slide.image.value == blank and slide.image_sp.value == blank
              continue
            endif
            assign slide_image = slide.image.value | default: slide.image_sp.value
            assign slide_image_sp = slide.image_sp.value | default: slide.image.value
            assign slide_alt = slide.title.value | default: slide_image.alt
            assign slide_url = slide.url.value
          -%}
          <swiper-slide class="!tw-h-auto tw-bg-white">
            {% if slide_url != blank %}<a href="{{ slide_url | escape }}" class="tw-text-current">{% endif %}
            <div class="cpb-main-visual__item">
              <picture>
                <source
                  media="(max-width: 768px)"
                  srcset="{{ slide_image_sp | image_url: width: 750 }}"
                >
                <img
                  class="tw-block tw-h-auto tw-w-full"
                  src="{{ slide_image | image_url: width: 780 }}"
                  alt="{{ slide_alt | escape }}"
                  width="{{ slide_image.width }}"
                  height="{{ slide_image.height }}"
                >
              </picture>
            </div>
            {% if slide_url != blank %}</a>{% endif %}
          </swiper-slide>
        {% endfor %}
        <div class="swiper-pagination swiper-pagination-white" slot="pagination"></div>
      </swiper-container>
    </div>
  </div>
{% endif %}

{% schema %}
{
  "name": "雪肌精BLUEスライダー",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "presets": [
    {
      "name": "雪肌精BLUEスライダー"
    }
  ]
}
{% endschema %}
