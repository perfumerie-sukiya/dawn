{{ 'template-collection.css' | asset_url | stylesheet_tag }}
{{ 'component-loading-spinner.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'component-slider.css' | asset_url | stylesheet_tag }}

{% if section.settings.image_shape == 'blob' %}
  {{ 'mask-blobs.css' | asset_url | stylesheet_tag }}
{%- endif -%}

{%- if section.settings.enable_quick_add -%}
  {{ 'quick-add.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'quick-add.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{%- style -%}
  .section-{{ section.id }}-padding {
  padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
  padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  .cpb-brand-page .cpb-contents-nav a,
  .cpb-brand-page .sp-only a {
    color: #000;
  }
  .cpb-brand-page .cpb-contents-nav a:hover,
  .cpb-brand-page .sp-only a:hover {
    color: #000;
  }
  .elegance-products-board {
    max-width: 1200px;
    margin: 0 auto;
  }
  .elegance-products-title {
    color: #b3a06a;
    letter-spacing: 0.12em;
    font-weight: 500;
  }
  .elegance-group-title {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    margin-bottom: 1rem;
    color: #b3a06a;
    letter-spacing: 0.1em;
    font-weight: 500;
  }
  .elegance-group-title::before,
  .elegance-group-title::after {
    content: '';
    height: 1px;
    background: #dcd8cc;
    flex: 1;
  }
  .elegance-item-image {
    max-height: 88px;
    object-fit: contain;
  }
  .elegance-item-label {
    margin-top: 0.5rem;
    font-size: 0.8rem;
    letter-spacing: 0.06em;
    color: #666;
  }
  @media screen and (min-width: 750px) {
  .section-{{ section.id }}-padding {
  padding-top: {{ section.settings.padding_top }}px;
  padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  }
{%- endstyle -%}

{%- liquid
  assign products_to_display = section.settings.products_to_show

  assign show_mobile_slider = false
  assign show_mobile_slider = true

  assign show_desktop_slider = false
  assign show_desktop_slider = true

  # Determine selected tag from Storefront Filtering (filter.p.tag) または旧来の current_tags
  assign filter_tag = ''
  for filter in collection.filters
    if filter.param_name == 'filter.p.tag'
      if filter.active_values != blank
        assign filter_tag = filter.active_values.first.label
      endif
      break
    endif
  endfor
  if filter_tag == ''
    assign filter_tag = current_tags | first
  endif
-%}

{% comment %}
  filter.p.tag パラメータが Shopify の Storefront Filter API で認識されない場合、
  旧形式の URL (/collections/elegance/tag-name) にリダイレクトする
{% endcomment %}
{% unless filter_tag %}
  <script>
    (function() {
      var params = new URLSearchParams(window.location.search);
      var tagParam = params.get('filter.p.tag');
      if (tagParam) {
        var newUrl = window.location.pathname + '/' + encodeURIComponent(tagParam);
        var viewParam = params.get('view');
        if (viewParam) {
          newUrl += '?view=' + encodeURIComponent(viewParam);
        }

        if (window.location.hash) {
          newUrl += window.location.hash;
        }

        window.location.replace(newUrl);
      }
    })();
  </script>
{% endunless %}

<!-- Elegance -->
<div class="item-list cpb-brand-page">
  {% if filter_tag %}
    <!-- Elegance商品一覧ここから -->
    <div class="page-width tw-my-5">
      <h3 class="tw-text-2xl tw-font-bold tw-my-2">{{ filter_tag }}</h3>
    </div>
    <div id="Collection" class="section-{{ section.id }}-padding">
      {%- paginate collection.products by section.settings.products_per_page -%}
        {% comment %} Sort is the first tabbable element when filter type is vertical {% endcomment %}
        {%- if section.settings.enable_sorting and section.settings.filter_type == 'vertical' -%}
          <facet-filters-form class="facets facets-vertical-sort page-width small-hide no-js-hidden">
            <form class="facets-vertical-form" id="FacetSortForm">
              <div class="facet-filters sorting caption">
                <div class="facet-filters__field">
                  <h2 class="facet-filters__label caption-large text-body">
                    <label for="SortBy">{{ 'products.facets.sort_by_label' | t }}</label>
                  </h2>
                  <div class="select">
                    {%- assign sort_by = collection.sort_by | default: collection.default_sort_by -%}
                    <select
                      name="sort_by"
                      class="facet-filters__sort select__select caption-large"
                      id="SortBy"
                      aria-describedby="a11y-refresh-page-message"
                    >
                      {%- for option in collection.sort_options -%}
                        <option
                          value="{{ option.value | escape }}"
                          {% if option.value == sort_by %}
                            selected="selected"
                          {% endif %}
                        >
                          {{ option.name | escape }}
                        </option>
                      {%- endfor -%}
                    </select>
                    {% render 'icon-caret' %}
                  </div>
                </div>
                <noscript>
                  <button type="submit" class="facets__button-no-js button button--secondary">
                    {{ 'products.facets.sort_button' | t }}
                  </button>
                </noscript>
              </div>

              <div class="product-count-vertical light" role="status">
                <h2 class="product-count__text text-body">
                  <span id="ProductCountDesktop">
                    {%- if collection.results_count -%}
                      {{
                        'templates.search.results_with_count'
                        | t: terms: collection.terms, count: collection.results_count
                      }}
                    {%- elsif collection.products_count == collection.all_products_count -%}
                      {{ 'products.facets.product_count_simple' | t: count: collection.products_count }}
                    {%- else -%}
                      {{
                        'products.facets.product_count'
                        | t: product_count: collection.products_count, count: collection.all_products_count
                      }}
                    {%- endif -%}
                  </span>
                </h2>
                <div class="loading__spinner">
                  <svg
                    aria-hidden="true"
                    focusable="false"
                    class="spinner"
                    viewBox="0 0 66 66"
                    xmlns="http://www.w3.org/2000/svg"
                  >
                    <circle class="path" fill="none" stroke-width="6" cx="33" cy="33" r="30"></circle>
                  </svg>
                </div>
              </div>
            </form>
          </facet-filters-form>
        {%- endif -%}

        <div class="{% if section.settings.filter_type == 'vertical' %} facets-vertical page-width{% endif %}">
          {{ 'component-facets.css' | asset_url | stylesheet_tag }}
          <script src="{{ 'facets.js' | asset_url }}" defer="defer"></script>
          {%- if section.settings.enable_filtering or section.settings.enable_sorting -%}
            <aside
              aria-labelledby="verticalTitle"
              class="facets-wrapper{% unless section.settings.enable_filtering %} facets-wrapper--no-filters{% endunless %}{% if section.settings.filter_type != 'vertical' %} page-width{% endif %}"
              id="main-collection-filters"
              data-id="{{ section.id }}"
            >
              {% render 'facets',
                results: collection,
                enable_filtering: section.settings.enable_filtering,
                enable_sorting: section.settings.enable_sorting,
                filter_type: section.settings.filter_type,
                paginate: paginate
              %}
            </aside>
          {%- endif -%}

          <div
            class="product-grid-container{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
            id="ProductGridContainer"
            {% if settings.animations_reveal_on_scroll %}
              data-cascade
            {% endif %}
          >
            {%- if collection.products.size == 0 -%}
              <div class="collection collection--empty page-width" id="product-grid" data-id="{{ section.id }}">
                <div class="loading-overlay gradient"></div>
                <div class="title-wrapper center">
                  <h2 class="title title--primary">
                    {{ 'sections.collection_template.empty' | t -}}
                    <br>
                    {{
                      'sections.collection_template.use_fewer_filters_html'
                      | t: link: collection.url, class: 'underlined-link link'
                    }}
                  </h2>
                </div>
              </div>
            {%- else -%}
              <div class="collection{% if section.settings.filter_type != 'vertical' %} page-width{% endif %}">
                <div class="loading-overlay gradient"></div>

                <ul
                  id="product-grid"
                  data-id="{{ section.id }}"
                  class="
                    grid product-grid grid--{{ section.settings.columns_mobile }}-col-tablet-down
                    grid--{{ section.settings.columns_desktop }}-col-desktop
                  "
                >
                  {%- for product in collection.products -%}
                    {% assign lazy_load = false %}
                    {%- if forloop.index > 2 -%}
                      {%- assign lazy_load = true -%}
                    {%- endif -%}
                    <li
                      class="grid__item{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
                      {% if settings.animations_reveal_on_scroll %}
                        data-cascade
                        style="--animation-order: {{ forloop.index }};"
                      {% endif %}
                    >
                      {% render 'card-product',
                        card_product: product,
                        media_aspect_ratio: section.settings.image_ratio,
                        image_shape: section.settings.image_shape,
                        show_secondary_image: section.settings.show_secondary_image,
                        show_vendor: section.settings.show_vendor,
                        show_rating: section.settings.show_rating,
                        lazy_load: lazy_load,
                        show_quick_add: section.settings.enable_quick_add,
                        max_title_length: section.settings.max_title_length,
                        section_id: section.id
                      %}
                    </li>
                  {%- endfor -%}
                </ul>

                {%- if paginate.pages > 1 -%}
                  {% render 'pagination', paginate: paginate, anchor: '' %}
                {%- endif -%}
              </div>
            {%- endif -%}
          </div>
        </div>
      {%- endpaginate -%}
      {% if section.settings.image_shape == 'arch' %}
        {% render 'mask-arch' %}
      {%- endif -%}

    </div>
    <!-- Elegance商品一覧ここまで -->
  {% else %}
    <!-- Eleganceブランドトップ -->
    <div class="page-width">
      {%- if section.settings.new_arrival_collection != blank -%}
      <div class="cpb-items tw-my-10">
        <h3 class="tw-text-center tw-text-3xl tw-mb-8 elegance-products-title">NEW ARRIVALS</h3>
        <slider-component class="slider-mobile-gutter{% if section.settings.full_width %} slider-component-full-width{% endif %}{% if show_mobile_slider == false %} page-width{% endif %}{% if show_desktop_slider == false and section.settings.full_width == false %} page-width-desktop{% endif %}{% if show_desktop_slider %} slider-component-desktop{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
          <ul
            id="Slider-{{ section.id }}-new-arrival"
            class="grid product-grid contains-card contains-card--product{% if settings.card_style == 'standard' %} contains-card--standard{% endif %} grid--{{ section.settings.columns_desktop }}-col-desktop{% if section.settings.new_arrival_collection == blank %} grid--2-col-tablet-down{% else %} grid--{{ section.settings.columns_mobile }}-col-tablet-down{% endif %}{% if show_mobile_slider or show_desktop_slider %} slider{% if show_desktop_slider %} slider--desktop{% endif %}{% if show_mobile_slider %} slider--tablet grid--peek{% endif %}{% endif %}"
            role="list"
            aria-label="{{ 'general.slider.name' | t }}"
          >
            {%- for product in section.settings.new_arrival_collection.products limit: section.settings.products_to_show -%}
              <li
                id="Slide-{{ section.id }}-new-arrival-{{ forloop.index }}"
                class="grid__item{% if show_mobile_slider or show_desktop_slider %} slider__slide{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
                {% if settings.animations_reveal_on_scroll %}
                  data-cascade
                  style="--animation-order: {{ forloop.index }};"
                {% endif %}
              >
                {% render 'card-product',
                  card_product: product,
                  media_aspect_ratio: section.settings.image_ratio,
                  image_shape: section.settings.image_shape,
                  show_secondary_image: section.settings.show_secondary_image,
                  show_vendor: section.settings.show_vendor,
                  show_rating: section.settings.show_rating,
                  show_quick_add: section.settings.enable_quick_add,
                  max_title_length: section.settings.max_title_length,
                  section_id: section.id
                %}
              </li>
            {%- endfor -%}
          </ul>
          {%- if show_mobile_slider or show_desktop_slider -%}
            <div class="slider-buttons no-js-hidden">
              <button
                type="button"
                class="slider-button slider-button--prev"
                name="previous"
                aria-label="{{ 'general.slider.previous_slide' | t }}"
                aria-controls="Slider-{{ section.id }}-new-arrival"
              >
                {% render 'icon-caret' %}
              </button>
              <div class="slider-counter caption">
                <span class="slider-counter--current">1</span>
                <span aria-hidden="true"> / </span>
                <span class="visually-hidden">{{ 'general.slider.of' | t }}</span>
                <span class="slider-counter--total">{{ products_to_display }}</span>
              </div>
              <button
                type="button"
                class="slider-button slider-button--next"
                name="next"
                aria-label="{{ 'general.slider.next_slide' | t }}"
                aria-controls="Slider-{{ section.id }}-new-arrival"
              >
                {% render 'icon-caret' %}
              </button>
            </div>
          {%- endif -%}
        </slider-component>
      </div>
      {%- endif -%}
      {%- if section.settings.ranking_collection != blank -%}
      <div class="cpb-items tw-my-10">
        <h3 class="tw-text-center tw-text-3xl tw-mb-8 elegance-products-title">RANKING</h3>
        <slider-component class="slider-mobile-gutter{% if section.settings.full_width %} slider-component-full-width{% endif %}{% if show_mobile_slider == false %} page-width{% endif %}{% if show_desktop_slider == false and section.settings.full_width == false %} page-width-desktop{% endif %}{% if show_desktop_slider %} slider-component-desktop{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
          <ul
            id="Slider-{{ section.id }}-ranking"
            class="grid product-grid contains-card contains-card--product{% if settings.card_style == 'standard' %} contains-card--standard{% endif %} grid--{{ section.settings.columns_desktop }}-col-desktop{% if section.settings.ranking_collection == blank %} grid--2-col-tablet-down{% else %} grid--{{ section.settings.columns_mobile }}-col-tablet-down{% endif %}{% if show_mobile_slider or show_desktop_slider %} slider{% if show_desktop_slider %} slider--desktop{% endif %}{% if show_mobile_slider %} slider--tablet grid--peek{% endif %}{% endif %}"
            role="list"
            aria-label="{{ 'general.slider.name' | t }}"
          >
            {%- for product in section.settings.ranking_collection.products limit: section.settings.products_to_show -%}
              <li
                id="Slide-{{ section.id }}-ranking-{{ forloop.index }}"
                class="grid__item{% if show_mobile_slider or show_desktop_slider %} slider__slide{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}{% if section.settings.ranking %} ranking-item{% endif %}"
                {% if settings.animations_reveal_on_scroll %}
                  data-cascade
                  style="--animation-order: {{ forloop.index }};"
                {% endif %}
              >
                {% if section.settings.ranking %}
                  <span class="rank">{{ forloop.index }}</span>
                {% endif %}
                {% render 'card-product',
                  card_product: product,
                  media_aspect_ratio: section.settings.image_ratio,
                  image_shape: section.settings.image_shape,
                  show_secondary_image: section.settings.show_secondary_image,
                  show_vendor: section.settings.show_vendor,
                  show_rating: section.settings.show_rating,
                  show_quick_add: section.settings.enable_quick_add,
                  max_title_length: section.settings.max_title_length,
                  section_id: section.id
                %}
              </li>
            {%- endfor -%}
          </ul>
          {%- if show_mobile_slider or show_desktop_slider -%}
            <div class="slider-buttons no-js-hidden">
              <button
                type="button"
                class="slider-button slider-button--prev"
                name="previous"
                aria-label="{{ 'general.slider.previous_slide' | t }}"
                aria-controls="Slider-{{ section.id }}-ranking"
              >
                {% render 'icon-caret' %}
              </button>
              <div class="slider-counter caption">
                <span class="slider-counter--current">1</span>
                <span aria-hidden="true"> / </span>
                <span class="visually-hidden">{{ 'general.slider.of' | t }}</span>
                <span class="slider-counter--total">{{ products_to_display }}</span>
              </div>
              <button
                type="button"
                class="slider-button slider-button--next"
                name="next"
                aria-label="{{ 'general.slider.next_slide' | t }}"
                aria-controls="Slider-{{ section.id }}-ranking"
              >
                {% render 'icon-caret' %}
              </button>
            </div>
          {%- endif -%}
        </slider-component>
      </div>
      {%- endif -%}

      <div class="cpb-contents-nav tw-my-10">
        <div class="elegance-products-board">
          <p class="tw-text-center tw-text-3xl tw-mb-8 elegance-products-title">PRODUCTS</p>

          <div class="tw-grid md:tw-grid-cols-2 tw-gap-x-8 tw-gap-y-10 tw-mb-8">
            <div>
              <p class="elegance-group-title">POINT MAKEUP</p>
              <div class="tw-grid tw-grid-cols-2 md:tw-grid-cols-4 tw-gap-4">
                <a class="tw-text-center tw-no-underline tw-text-current" href="{{ routes.collections_url }}/elegance/アイ#Collection">
                  <img class="tw-w-full elegance-item-image" src="{{ 'elegance_category_aeenqj21.png' | file_url }}" alt="EYE" width="280" height="220">
                  <p class="elegance-item-label">EYE</p>
                </a>
                <a class="tw-text-center tw-no-underline tw-text-current" href="{{ routes.collections_url }}/elegance/リップ#Collection">
                  <img class="tw-w-full elegance-item-image" src="{{ 'elegance_category_aeentv09.png' | file_url }}" alt="LIP" width="280" height="220">
                  <p class="elegance-item-label">LIP</p>
                </a>
                <a class="tw-text-center tw-no-underline tw-text-current" href="{{ routes.collections_url }}/elegance/フェイスカラー#Collection">
                  <img class="tw-w-full elegance-item-image" src="{{ 'elegance_category_aeenqq05.png' | file_url }}" alt="FACE COLOR" width="280" height="220">
                  <p class="elegance-item-label">FACE COLOR</p>
                </a>
                <a class="tw-text-center tw-no-underline tw-text-current" href="{{ routes.collections_url }}/elegance/ネイル#Collection">
                  <img class="tw-w-full elegance-item-image" src="{{ 'elegance_category_aeenqp20.png' | file_url }}" alt="NAIL" width="280" height="220">
                  <p class="elegance-item-label">NAIL</p>
                </a>
              </div>
            </div>

            <div>
              <p class="elegance-group-title">BASE MAKEUP</p>
              <div class="tw-grid tw-grid-cols-3 tw-gap-4">
                <a class="tw-text-center tw-no-underline tw-text-current" href="{{ routes.collections_url }}/elegance/メイクアップベース#Collection">
                  <img class="tw-w-full elegance-item-image" src="{{ 'elegance_category_makeup-base.png' | file_url }}" alt="MAKEUP BASE" width="280" height="220">
                  <p class="elegance-item-label">MAKEUP BASE</p>
                </a>
                <a class="tw-text-center tw-no-underline tw-text-current" href="{{ routes.collections_url }}/elegance/ファンデーション#Collection">
                  <img class="tw-w-full elegance-item-image" src="{{ 'elegance_category_aeenpb01.png' | file_url }}" alt="FOUNDATION" width="280" height="220">
                  <p class="elegance-item-label">FOUNDATION</p>
                </a>
                <a class="tw-text-center tw-no-underline tw-text-current" href="{{ routes.collections_url }}/elegance/フェイスパウダー#Collection">
