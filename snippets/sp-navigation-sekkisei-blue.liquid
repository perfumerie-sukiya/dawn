{% comment %}
  雪肌精BLUE SPアコーディオンナビゲーション
  仕様書のカテゴリを固定表示し、各リンクはタグフィルタURLへ遷移する。
{% endcomment %}
{%- assign sekkisei_blue_url = routes.collections_url | append: '/sekkisei-blue' -%}
<script src="{{ 'my-accordion.js' | asset_url }}" defer="defer"></script>

<div class="sp-only">
  <my-accordion>
    <ul class="tw-bg-[#13509b] tw-text-white tw-mb-10 tw-p-0">
      <li class="tw-w-full tw-border-b tw-border-[#2f6cb5]"><a href="{{ sekkisei_blue_url }}#about-us" class="tw-flex tw-justify-between tw-items-center tw-p-4 tw-no-underline tw-text-current"><span>ABOUT US</span><span class="tw-inline-flex tw-text-white">{% render 'icon-chevron-right', width: 14, height: 14 %}</span></a></li>
      <li class="tw-w-full tw-border-b tw-border-[#2f6cb5]"><a href="{{ sekkisei_blue_url }}#new-arrival" class="tw-flex tw-justify-between tw-items-center tw-p-4 tw-no-underline tw-text-current"><span>NEW ARRIVAL</span><span class="tw-inline-flex tw-text-white">{% render 'icon-chevron-right', width: 14, height: 14 %}</span></a></li>
      <li class="tw-w-full tw-border-b tw-border-[#2f6cb5]"><a href="{{ sekkisei_blue_url }}#campaign" class="tw-flex tw-justify-between tw-items-center tw-p-4 tw-no-underline tw-text-current"><span>CAMPAIGN</span><span class="tw-inline-flex tw-text-white">{% render 'icon-chevron-right', width: 14, height: 14 %}</span></a></li>
      <li class="tw-w-full tw-border-b tw-border-[#2f6cb5]"><a href="{{ sekkisei_blue_url }}#ranking" class="tw-flex tw-justify-between tw-items-center tw-p-4 tw-no-underline tw-text-current"><span>RANKING</span><span class="tw-inline-flex tw-text-white">{% render 'icon-chevron-right', width: 14, height: 14 %}</span></a></li>
      <li class="tw-w-full tw-border-b tw-border-[#2f6cb5]">
        <div class="my-accordion tw-w-full tw-text-left tw-flex tw-justify-between tw-items-center tw-p-4">
          <span>PRODUCTS</span>
          <span class="tw-inline-flex tw-text-white" data-accordion-icon><span data-accordion-icon-closed>{% render 'icon-plus', width: 14, height: 14 %}</span><span data-accordion-icon-open hidden>{% render 'icon-minus', width: 14, height: 3 %}</span></span>
        </div>
        <div class="panel tw-bg-[#eef4fb] tw-text-black">
          <div class="my-accordion tw-w-full tw-text-left tw-flex tw-justify-between tw-items-center tw-p-4"><span>スキンケア</span><span class="tw-inline-flex tw-text-current" data-accordion-icon><span data-accordion-icon-closed>{% render 'icon-plus', width: 14, height: 14 %}</span><span data-accordion-icon-open hidden>{% render 'icon-minus', width: 14, height: 3 %}</span></span></div>
          <div class="panel tw-bg-white tw-grid tw-grid-cols-2">
            <a href="{{ sekkisei_blue_url }}/クレンジング" class="tw-block tw-p-4 tw-border tw-border-[#eef4fb] tw-no-underline tw-text-current">クレンジング</a>
            <a href="{{ sekkisei_blue_url }}/洗顔" class="tw-block tw-p-4 tw-border tw-border-[#eef4fb] tw-no-underline tw-text-current">洗顔</a>
            <a href="{{ sekkisei_blue_url }}/化粧水" class="tw-block tw-p-4 tw-border tw-border-[#eef4fb] tw-no-underline tw-text-current">化粧水</a>
            <a href="{{ sekkisei_blue_url }}/{{ '美容液/オイル' | handleize }}" class="tw-block tw-p-4 tw-border tw-border-[#eef4fb] tw-no-underline tw-text-current">美容液/オイル</a>
            <a href="{{ sekkisei_blue_url }}/クリーム" class="tw-block tw-p-4 tw-border tw-border-[#eef4fb] tw-no-underline tw-text-current">クリーム</a>
            <a href="{{ sekkisei_blue_url }}/UVケア" class="tw-block tw-p-4 tw-border tw-border-[#eef4fb] tw-no-underline tw-text-current">UVケア</a>
            <a href="{{ sekkisei_blue_url }}/トライアル" class="tw-block tw-p-4 tw-border tw-border-[#eef4fb] tw-no-underline tw-text-current">トライアル</a>
            <a href="{{ sekkisei_blue_url }}/限定品" class="tw-block tw-p-4 tw-border tw-border-[#eef4fb] tw-no-underline tw-text-current">限定品</a>
            <a href="{{ sekkisei_blue_url }}/スキンケア" class="tw-block tw-p-4 tw-border tw-border-[#eef4fb] tw-no-underline tw-text-current">すべて</a>
          </div>
          <div class="my-accordion tw-w-full tw-text-left tw-flex tw-justify-between tw-items-center tw-p-4"><span>ベースメイク</span><span class="tw-inline-flex tw-text-current" data-accordion-icon><span data-accordion-icon-closed>{% render 'icon-plus', width: 14, height: 14 %}</span><span data-accordion-icon-open hidden>{% render 'icon-minus', width: 14, height: 3 %}</span></span></div>
          <div class="panel tw-bg-white tw-grid tw-grid-cols-2">
            <a href="{{ sekkisei_blue_url }}/化粧下地" class="tw-block tw-p-4 tw-border tw-border-[#eef4fb] tw-no-underline tw-text-current">化粧下地</a>
            <a href="{{ sekkisei_blue_url }}/ファンデーション" class="tw-block tw-p-4 tw-border tw-border-[#eef4fb] tw-no-underline tw-text-current">ファンデーション</a>
            <a href="{{ sekkisei_blue_url }}/コンシーラー" class="tw-block tw-p-4 tw-border tw-border-[#eef4fb] tw-no-underline tw-text-current">コンシーラー</a>
            <a href="{{ sekkisei_blue_url }}/フェイスパウダー" class="tw-block tw-p-4 tw-border tw-border-[#eef4fb] tw-no-underline tw-text-current">フェイスパウダー</a>
            <a href="{{ sekkisei_blue_url }}/限定品" class="tw-block tw-p-4 tw-border tw-border-[#eef4fb] tw-no-underline tw-text-current">限定品</a>
            <a href="{{ sekkisei_blue_url }}/ベースメイク" class="tw-block tw-p-4 tw-border tw-border-[#eef4fb] tw-no-underline tw-text-current">すべて</a>
          </div>
          <div class="my-accordion tw-w-full tw-text-left tw-flex tw-justify-between tw-items-center tw-p-4"><span>ボディ</span><span class="tw-inline-flex tw-text-current" data-accordion-icon><span data-accordion-icon-closed>{% render 'icon-plus', width: 14, height: 14 %}</span><span data-accordion-icon-open hidden>{% render 'icon-minus', width: 14, height: 3 %}</span></span></div>
          <div class="panel tw-bg-white tw-grid tw-grid-cols-2">
            <a href="{{ sekkisei_blue_url }}/ボディケア" class="tw-block tw-p-4 tw-border tw-border-[#eef4fb] tw-no-underline tw-text-current">ボディケア</a>
            <a href="{{ sekkisei_blue_url }}/ハンドケア" class="tw-block tw-p-4 tw-border tw-border-[#eef4fb] tw-no-underline tw-text-current">ハンドケア</a>
            <a href="{{ sekkisei_blue_url }}/限定品" class="tw-block tw-p-4 tw-border tw-border-[#eef4fb] tw-no-underline tw-text-current">限定品</a>
            <a href="{{ sekkisei_blue_url }}/ボディ" class="tw-block tw-p-4 tw-border tw-border-[#eef4fb] tw-no-underline tw-text-current">すべて</a>
          </div>
          <div class="my-accordion tw-w-full tw-text-left tw-flex tw-justify-between tw-items-center tw-p-4"><span>ライフスタイル</span><span class="tw-inline-flex tw-text-current" data-accordion-icon><span data-accordion-icon-closed>{% render 'icon-plus', width: 14, height: 14 %}</span><span data-accordion-icon-open hidden>{% render 'icon-minus', width: 14, height: 3 %}</span></span></div>
          <div class="panel tw-bg-white tw-grid tw-grid-cols-2">
            <a href="{{ sekkisei_blue_url }}/フレグランスミスト" class="tw-block tw-p-4 tw-border tw-border-[#eef4fb] tw-no-underline tw-text-current">フレグランスミスト</a>
            <a href="{{ sekkisei_blue_url }}/ボディケア" class="tw-block tw-p-4 tw-border tw-border-[#eef4fb] tw-no-underline tw-text-current">ボディケア</a>
            <a href="{{ sekkisei_blue_url }}/ハンドケア" class="tw-block tw-p-4 tw-border tw-border-[#eef4fb] tw-no-underline tw-text-current">ハンドケア</a>
            <a href="{{ sekkisei_blue_url }}/限定品" class="tw-block tw-p-4 tw-border tw-border-[#eef4fb] tw-no-underline tw-text-current">限定品</a>
            <a href="{{ sekkisei_blue_url }}/ライフスタイル" class="tw-block tw-p-4 tw-border tw-border-[#eef4fb] tw-no-underline tw-text-current">すべて</a>
          </div>
          <a href="{{ sekkisei_blue_url }}/限定品" class="tw-flex tw-justify-between tw-items-center tw-p-4 tw-no-underline tw-text-current"><span>限定品</span><span class="tw-inline-flex tw-text-current">{% render 'icon-chevron-right', width: 14, height: 14 %}</span></a>
          <a href="{{ sekkisei_blue_url }}/その他" class="tw-flex tw-justify-between tw-items-center tw-p-4 tw-no-underline tw-text-current"><span>その他</span><span class="tw-inline-flex tw-text-current">{% render 'icon-chevron-right', width: 14, height: 14 %}</span></a>
        </div>
      </li>
      <li class="tw-w-full tw-border-b tw-border-[#2f6cb5]"><a href="https://sekkisei.jp/site/p/sekkiseiblue_counseling.aspx" target="_blank" rel="noopener" class="tw-flex tw-justify-between tw-items-center tw-p-4 tw-no-underline tw-text-current"><span>Find Balance</span><span class="tw-inline-flex tw-text-white">{% render 'icon-chevron-right', width: 14, height: 14 %}</span></a></li>
    </ul>
  </my-accordion>
</div>
