{{ 'dialog-polyfill.css' | asset_url | stylesheet_tag }}
{{ 'counseling-modal.css' | asset_url | stylesheet_tag }}
<script src="{{ 'dialog-polyfill.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'counseling-modal.js' | asset_url }}" defer="defer"></script>
<style>
  .counseling-start-action #ProductSubmitButton-{{ section_id }}.gPreorderHidden {
    display: block !important;
    visibility: visible !important;
  }
</style>

<my-dialog id="myDialog" data-brand="albion" data-input-type="checkbox">
  <dialog class="tw-w-[600px] tw-max-w-[90%]">
    <div class="page">
      <div class="counseling-content">
        <div>
          <h4 class="md:tw-text-xl tw-mb-4 tw-tracking-wider">お客様の肌状態に関するカウンセリング</h4>
          <div class="tw-bg-gray-100 tw-mb-5 tw-p-5 tw-text-xs">
            <p class="md:tw-leading-8 tw-tracking-widest">
              商品購入前に肌安全性確認のため、下記の項目にご回答ください。<br>
              ご自身に当てはまる項目にチェックを入れてください。</p>
          </div>
          <div class="counseling-question-list tw-space-y-4">
            <label for="q1-{{ section_id }}" class="counseling-question-item tw-border tw-border-gray-300 tw-rounded-xl tw-p-4 tw-flex tw-items-start tw-gap-3 tw-cursor-pointer tw-block tw-transition-colors hover:tw-bg-gray-50 tw-select-none">
              <input type="checkbox" id="q1-{{ section_id }}" name="q1-{{ section_id }}" value="1" class="counseling-checkbox tw-mt-1 tw-flex-shrink-0 tw-w-5 tw-h-5 tw-rounded tw-border-gray-400">
              <span class="tw-flex-1">
                <p class="tw-text-sm tw-mb-1">現在、皮膚科に通院するような肌トラブルを起こしていない。</p>
                <p class="tw-mb-0 tw-text-xs tw-text-gray-600"><small>※肌トラブル：炎症・アトピー・赤味・はれ・かゆみ・刺激・色抜け(白斑)・黒ずみなど</small></p>
              </span>
            </label>
            <label for="q2-{{ section_id }}" class="counseling-question-item tw-border tw-border-gray-300 tw-rounded-xl tw-p-4 tw-flex tw-items-start tw-gap-3 tw-cursor-pointer tw-block tw-transition-colors hover:tw-bg-gray-50 tw-select-none">
              <input type="checkbox" id="q2-{{ section_id }}" name="q2-{{ section_id }}" value="1" class="counseling-checkbox tw-mt-1 tw-flex-shrink-0 tw-w-5 tw-h-5 tw-rounded tw-border-gray-400">
              <span class="tw-flex-1">
                <p class="tw-text-sm tw-mb-0">過去に化粧品で肌トラブルを起こしたことがない。</p>
              </span>
            </label>
            <label for="q3-{{ section_id }}" class="counseling-question-item tw-border tw-border-gray-300 tw-rounded-xl tw-p-4 tw-flex tw-items-start tw-gap-3 tw-cursor-pointer tw-block tw-transition-colors hover:tw-bg-gray-50 tw-select-none">
              <input type="checkbox" id="q3-{{ section_id }}" name="q3-{{ section_id }}" value="1" class="counseling-checkbox tw-mt-1 tw-flex-shrink-0 tw-w-5 tw-h-5 tw-rounded tw-border-gray-400">
              <span class="tw-flex-1">
                <p class="tw-text-sm tw-mb-0">自身の肌は、揺らぎやすく、敏感・不安定ではない。</p>
              </span>
            </label>
          </div>
          <div class="tw-flex tw-justify-center tw-gap-2 tw-mt-8">
            <div
                class="close-button tw-basis-1/2 tw-bg-slate-800 tw-text-white tw-text-center tw-p-2 tw-cursor-pointer">
              閉じる
            </div>
            <div
                class="next-page-disable tw-basis-1/2 tw-text-white tw-text-center tw-p-2 tw-bg-gray-300"
            >次へ
            </div>
            <div
                class="next-page tw-basis-1/2 tw-bg-black tw-text-white tw-text-center tw-p-2 tw-cursor-pointer tw-hidden"
            >次へ
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="page">
      <div class="counseling-content tw-p-2 md:tw-p-6">
        <div class="counseling-result">
          <h4 class="md:tw-text-xl tw-mb-4 tw-tracking-wider">お客様の肌状態に関するカウンセリング結果</h4>
          <p class="tw-text-sm tw-text-center tw-p-3 md:tw-p-6">購入前カウンセリングが完了しました。<br/>引き続き、お買い物をお楽しみください。</p>
          <div class="counseling-start-action tw-flex tw-flex-col tw-gap-3">
            <button
                id="ProductSubmitButton-{{ section_id }}"
                type="submit"
                name="add"
                class="product-form__submit button button--full-width button--primary"
            >
              <span>{{ 'products.product.add_to_cart' | t }}</span>
            </button>
            <a href="{{ routes.cart_url }}" class="tw-w-full tw-bg-black tw-text-white tw-text-center tw-py-3 tw-no-underline tw-block">カートを見る</a>
            <button type="button" class="close-button tw-w-full tw-bg-slate-800 tw-text-white tw-text-center tw-py-3 tw-cursor-pointer tw-border-0">お買い物を続ける</button>
          </div>
          <p class="tw-mt-6 tw-mb-3 tw-text-sm">ご購入前に、詳しいカウンセリングをご希望の場合</p>
          <div class="tw-gap-2 tw-text-center">
            <a href="https://www.albion.co.jp/counseling/" target="_blank" rel="noopener" class="tw-no-underline">
              <div class="tw-w-full tw-bg-slate-800 tw-text-white tw-text-center tw-p-2 tw-cursor-pointer">オンラインカウンセリング</div>
            </a>
            <p class="tw-mt-2"><small>＜外部サイトへ遷移いたします＞</small></p>
          </div>
        </div>
        <div class="counseling-result">
          <h4 class="md:tw-text-xl tw-mb-4 tw-tracking-wider">お客様の肌状態に関するカウンセリング結果</h4>
          <p class="tw-text-sm tw-mb-4">ご購入にあたっては、商品情報・全成分をご確認ください。</p>
          <div class="tw-bg-gray-100 tw-mb-5 tw-p-5 tw-text-xs">
            <p class="tw-p-4 md:tw-leading-8 tw-tracking-widest">
              あわせてご使用前には、腕の内側など目立たない部位に少量でお試しいただき、問題がないかご確認の上、ご使用ください。</p>
          </div>
          <div class="counseling-start-action tw-flex tw-flex-col tw-gap-3">
            <button
                id="ProductSubmitButton-{{ section_id }}"
                type="submit"
                name="add"
                class="product-form__submit button button--full-width button--primary"
            >
              <span>確認してカートに追加</span>
            </button>
            <a href="https://www.albion.co.jp/counseling/" target="_blank" rel="noopener" class="tw-no-underline">
              <div class="tw-w-full tw-bg-slate-800 tw-text-white tw-text-center tw-py-3 tw-cursor-pointer">カートに入れてカウンセリングをする</div>
            </a>
          </div>
          <p class="tw-mt-4 tw-text-xs tw-text-gray-600"><small>＜カウンセリングは外部サイトへ遷移いたします＞</small></p>
        </div>
        <div class="counseling-result">
          <h4 class="md:tw-text-xl tw-mb-4 tw-tracking-wider">お客様の肌状態に関するカウンセリング結果</h4>
          <p class="tw-text-sm tw-mb-6">申し訳ございませんが販売できません。</p>
          <p class="tw-text-sm tw-mb-6">皮膚科専門医の受診をお勧めします。</p>
          <div class="counseling-start-action tw-flex tw-flex-col tw-gap-3">
            <button type="button" class="retry-counseling tw-w-full tw-bg-slate-800 tw-text-white tw-text-center tw-py-3 tw-cursor-pointer tw-border-0">もう一度カウンセリングをする</button>
            <button type="button" class="close-button tw-w-full tw-bg-gray-300 tw-text-black tw-text-center tw-py-3 tw-cursor-pointer tw-border-0">この画面を閉じる</button>
          </div>
        </div>
      </div>
    </div>
  </dialog>
</my-dialog>

