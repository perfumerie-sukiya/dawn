    <li class="tw-border-b tw-border-gray-200 last:tw-border-b-0">
      <a href="{{ ignis_io_collection_url }}?filter.p.tag=handcare" class="tw-flex tw-justify-between tw-items-center tw-p-4 tw-no-underline tw-text-black">Handcare</a>
    </li>
