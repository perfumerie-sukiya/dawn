  <ul class="tw-list-none tw-pl-0 tw-m-0 tw-border tw-border-gray-200">
    <li class="tw-border-b tw-border-gray-200 last:tw-border-b-0">
      <a href="{{ ignis_io_collection_url }}?filter.p.tag=skincare" class="tw-flex tw-justify-between tw-items-center tw-p-4 tw-no-underline tw-text-black">Skincare</a>
    </li>
    <li class="tw-border-b tw-border-gray-200 last:tw-border-b-0">
      <a href="{{ ignis_io_collection_url }}?filter.p.tag=UV" class="tw-flex tw-justify-between tw-items-center tw-p-4 tw-no-underline tw-text-black">UV</a>
