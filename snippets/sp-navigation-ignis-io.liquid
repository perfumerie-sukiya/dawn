{% comment %}
  IGNIS iO カテゴリページ下部 SP用カテゴリナビ
  6カテゴリのシンプルなリスト
{% endcomment %}
{% assign ignis_io_collection_url = routes.collections_url | append: '/ignis-io' %}

<div class="sp-only tw-mt-8">
