    <a class="tw-h-10 tw-px-4 tw-py-2 tw-flex tw-items-center tw-text-sm tw-tracking-widest tw-no-underline tw-text-current" href="{{ elegance_collection_url }}/ポイントメイク#Collection">
      ポイントメイク
      <span class="tw-inline-flex tw-text-lg tw-leading-none tw-text-current">{% render 'icon-chevron-right' %}</span>
    </a>
    <div class="nested-menu group-hover:tw-block tw-hidden tw-bg-white">
      <a class="tw-px-4 tw-py-2 tw-flex tw-items-center tw-text-sm tw-tracking-widest tw-no-underline tw-text-current hover:tw-bg-slate-50" href="{{ elegance_collection_url }}/アイ#Collection">アイ</a>
